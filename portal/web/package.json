{
  "name": "dstu-portal-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript-фронтенд порталу підписання (ДСТУ 4163 + НПА)",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/app.ts --outfile ./app.js --target browser --format esm",
    "watch": "bun build ./src/app.ts --outfile ./app.js --target browser --format esm --watch"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
